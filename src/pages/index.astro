---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import PageContent from '../components/ui/PageContent.astro';
import AnimatedContent from '../components/ui/AnimatedContent.astro';
import CardGrid from '../components/ui/CardGrid.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import ThemeToast from '../components/ui/ThemeToast.astro';
import HeroShapes from '../components/home/HeroShapes.astro';
import {
  WhatIDoVisual,
  TheCraftVisual,
  HowIWorkVisual,
  BeyondTheRoleVisual,
  ExperienceSnapshotVisual
} from '../components/home/SectionVisuals.tsx';
import HomeSection from '../components/home/HomeSection.astro';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3); // Get latest 3 posts for homepage

const featuredDeepdive = (await getCollection('deepdives'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

<BaseLayout title="Systemic Design for High-Growth Products | Maxence Mauduit" description="Product Design Leader (CDO) specializing in building interaction systems that bridge complex business logic and high-performance user experiences.">
  <Header />
  <!-- Hero Section - Full Viewport -->
  <section class="min-h-screen flex flex-col items-center justify-center px-3 md:px-0">
    <div class="w-full max-w-2xl mx-auto text-center">
      <AnimatedContent delay={0}>
        <div class="hero-profile-wrapper">
          <img
            src="/images/profile.jpeg"
            alt="Maxence Mauduit"
            class="hero-profile-photo"
            width="240"
            height="240"
          />
          <HeroShapes />
        </div>
      </AnimatedContent>
      <AnimatedContent delay={100}>
        <h1 class="text-center text-3xl md:text-5xl m-0 leading-tight font-heading font-normal text-theme">
          Turning early product decisions into scalable platforms.
        </h1>
      </AnimatedContent>
      <AnimatedContent delay={200}>
        <p class="text-center mt-4 text-base md:text-lg font-body font-normal max-w-2xl mx-auto px-4 text-theme">
          Product & experience executive with 13+ years shaping monetization and platform products, building independent teams, and maintaining experience coherence under growth pressure.<br />Still hands-on where it matters.
        </p>
      </AnimatedContent>
    </div>
  </section>
  
  <!-- Main Content Sections -->
  <PageContent class="flex flex-col">
    {/* WHAT I DO */}
    <HomeSection title="WHAT I DO" delay={0}>
      <p slot="pre-visual" class="mt-4">I work at the intersection of product definition, interaction design, and execution systems.</p>
      <WhatIDoVisual slot="visual" client:visible />
      <div slot="post-visual">
        <p class="mt-4">My strength is taking problems that are still undefined, strategically sensitive, or technically constrained, and turning them into products teams can actually build and scale. Sometimes that means leading. Sometimes that means designing the first version myself and stepping away once the direction is clear.</p>
        <p class="mt-4">
          <a href="/images/Maxence-Mauduit_Resume-2026.pdf" target="_blank" rel="noopener noreferrer" class="inline-card"><img src="/images/favicon.png" alt="" width="14" height="14" class="inline-card-icon" />View my resume</a> for a detailed overview of my experience and impact.
        </p>
      </div>
    </HomeSection>
    
    {/* THE CRAFT */}
    <HomeSection title="THE CRAFT" delay={25}>
      <p slot="pre-visual" class="mt-4">Code as a design tool — before AI, and even more with it.</p>
      <TheCraftVisual slot="visual" client:visible />
      <div slot="post-visual">
        <div class="mt-6">
          <p>I've always used code as a design tool — building shared systems, prototyping interactions too complex for Figma, and closing the gap between intent and implementation. AI coding agents turned that into a superpower. With a structured control system I designed for autonomous agent work, I now fully leverage my cross-disciplinary fluency in design, product, and engineering at a pace that wasn't possible before.</p>
        </div>

        <div class="craft-grid mt-10">
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Interaction</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Primitives, micro-interactions, and system-level patterns that scale across products.</p>
            <div class="ref-links">
              <a href="/blog/when-the-interface-assembles-itself" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />When the Interface Assembles Itself</a>
              <a href="/blog/designing-above-the-interface" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />Designing Above the Interface</a>
              <a href="/blog/from-paper-to-code" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />From Paper to Code</a>
            </div>
          </div>
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Engineering</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Shipping design decisions directly in production codebases.</p>
            <div class="ref-links">
              <a href="/about/" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />About This Site</a>
              <a href="/blog/from-paper-to-code" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />From Paper to Code</a>
            </div>
          </div>
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Systems</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Component libraries and design tokens that hold across products and teams.</p>
            <div class="ref-links">
              <a href="https://design.buzzvil.com" target="_blank" rel="noopener noreferrer" class="ref-link"><img src="https://www.google.com/s2/favicons?domain=design.buzzvil.com&sz=24" alt="" class="ref-icon" width="14" height="14" />Design Buzzvil</a>
            </div>
          </div>
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Product</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Scoping, sequencing, and making tradeoffs before pixels.</p>
            <div class="ref-links">
              <a href="/deepdives/ai-native-design-workflow-playbook" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />AI-Native Design Playbook</a>
              <a href="/blog/designing-above-the-interface" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />Designing Above the Interface</a>
              <a href="/blog/harnessing-ai-coding-agents" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />Agent Operating Manual</a>
            </div>
          </div>
        </div>
      </div>
    </HomeSection>

    {/* EXPERIENCE SNAPSHOT */}
    <HomeSection title="EXPERIENCE SNAPSHOT" delay={50}>
      <p slot="pre-visual" class="mt-4">13+ years of shaping products, building teams, and scaling platforms.</p>
      <ExperienceSnapshotVisual slot="visual" client:visible />
      <div slot="post-visual">
        <div class="mt-8">
          <h2 class="text-2xl md:text-3xl font-light font-body !mb-0">Product & Experience Executive</h2>
          <p class="text-base font-normal mt-1 text-theme-muted">Buzzvil · Seoul · 2014–Present</p>
          
          <ul class="mt-6 space-y-2 list-none pl-0">
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Shaped first iterations of nearly every major product and monetization model</span>
            </li>
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Led the company through a major pivot from consumer products to B2B Ads and SDK platforms</span>
            </li>
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Built and scaled a high-retention design team with strong product ownership</span>
            </li>
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Currently institutionalizing execution and experience coherence in preparation for IPO</span>
            </li>
          </ul>
          <div class="ref-links mt-6">
            <span class="ref-label">See also:</span>
            <a href="/blog/i-dont-like-ads" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />I Don't Like Ads</a>
            <a href="https://www.buzzvil.com/en/company/about_us" target="_blank" rel="noopener noreferrer" class="ref-link"><img src="https://www.google.com/s2/favicons?domain=buzzvil.com&sz=24" alt="" class="ref-icon" width="14" height="14" />About Us</a>
            <a href="https://docs.buzzvil.com/" target="_blank" rel="noopener noreferrer" class="ref-link"><img src="https://www.google.com/s2/favicons?domain=docs.buzzvil.com&sz=24" alt="" class="ref-icon" width="14" height="14" />Buzzvil Docs</a>
            <a href="https://buzzvil.github.io/design/" target="_blank" rel="noopener noreferrer" class="ref-link"><img src="https://www.google.com/s2/favicons?domain=buzzvil.github.io&sz=24" alt="" class="ref-icon" width="14" height="14" />Design Buzzvil</a>
          </div>
        </div>
        
        <div class="mt-12">
          <h2 class="text-2xl md:text-3xl font-light font-body !mb-0">UX Design Lead</h2>
          <p class="text-base font-normal mt-1 text-theme-muted">CMS Group · Paris · 2011–2014</p>
          
          <ul class="mt-6 space-y-2 list-none pl-0">
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Led UX for enterprise and SaaS products</span>
            </li>
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Co-published research on co-design validation methods</span>
            </li>
            <li class="flex items-start">
              <span class="mr-2 text-theme-muted">•</span>
              <span>Built an education SaaS bridging design intent and production code</span>
            </li>
          </ul>
        </div>
        
        <div class="mt-8">
          <p class="text-base">For more details, see my <a href="/timeline" class="inline-card"><img src="/images/favicon.png" alt="" width="14" height="14" class="inline-card-icon" />full experience timeline</a>.</p>
        </div>
      </div>
    </HomeSection>
    
    {/* HOW I WORK */}
    <HomeSection title="HOW I WORK" delay={100}>
      <p slot="pre-visual" class="mt-4">Tight discovery loops, clear intent, and execution that doesn't depend on me.</p>
      <HowIWorkVisual slot="visual" client:visible />
      <div slot="post-visual">
        <div class="craft-grid mt-10">
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Deliberate thinking, fast execution</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Investing heavily upfront to clarify constraints, tradeoffs, and intent, so execution moves quickly without rework.</p>
            <div class="ref-links">
              <a href="/blog/design-tempo" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />Design Tempo</a>
            </div>
          </div>
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Systems over screens</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Interaction models, primitives, and patterns that hold together across teams and iterations.</p>
          </div>
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Product ownership mindset</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Designing with unit economics, engineering cost, and long-term maintainability in mind.</p>
            <div class="ref-links">
              <a href="/blog/high-output-management" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />High Output Management</a>
            </div>
          </div>
          <div class="craft-cell">
            <h3 class="text-base font-heading font-bold">Building teams that don't need me</h3>
            <p class="text-base leading-relaxed text-theme-muted !mt-0">Small teams designed to operate without constant oversight. Removing ambiguity early and becoming unnecessary over time.</p>
            <div class="ref-links">
              <a href="/blog/design-peer-reviews-to-support-our-team-growth" class="ref-link"><img src="/images/favicon.png" alt="" class="ref-icon" width="14" height="14" />Design Peer Reviews</a>
            </div>
          </div>
        </div>
      </div>
    </HomeSection>
    
    {/* BEYOND THE ROLE */}
    <HomeSection title="BEYOND THE ROLE" delay={200}>
      <p slot="pre-visual" class="mt-4">Sustainable pace, continuous learning, and systems thinking beyond work.</p>
      <BeyondTheRoleVisual slot="visual" client:visible />
      <div slot="post-visual">
        <p class="mt-4">I value sustainable performance and depth over constant acceleration.</p>
        <p class="mt-4">Outside of work, I'm a parent of two and spend my time learning how complex systems behave, from interaction design to human psychology. I wrote about that balance: <a href="/blog/life-in-sprint-mode-raising-two-kids-while-working-at-a-hyper-dynamic-korean-startup" class="inline-card"><img src="/images/favicon.png" alt="" width="14" height="14" class="inline-card-icon" />Life in Sprint Mode</a>.</p>
      </div>
    </HomeSection>
    
    {/* Featured Deep Dive */}
    {featuredDeepdive && (
      <section class="flex flex-col items-center px-3 md:px-8 lg:px-12 py-12 md:py-16">
        <div class="w-full max-w-5xl mx-auto text-base leading-relaxed index text-theme">
          <AnimatedContent delay={325}>
            <div class="w-full">
              <h2 class="text-2xl md:text-3xl font-light font-body !mb-0">Featured Deep Dive</h2>
              <a href={`/deepdives/${featuredDeepdive.slug}/`} class="featured-deepdive-card mt-12 block no-underline border-none hover:bg-transparent">
                <article class="p-6 md:p-10" style="border: 1px solid var(--theme-border); border-radius: var(--theme-radius);">
                  <p class="text-xs uppercase tracking-widest mb-4" style="color: var(--theme-text-muted);">Deep Dive</p>
                  <h3 class="text-2xl md:text-4xl font-mono font-light mb-3" style="color: var(--theme-text);">
                    {featuredDeepdive.data.title}
                  </h3>
                  {featuredDeepdive.data.description && (
                    <p class="text-base md:text-lg leading-relaxed" style="color: var(--theme-text-muted);">
                      {featuredDeepdive.data.description}
                    </p>
                  )}
                  <p class="mt-6 text-sm font-mono" style="color: var(--theme-text);">Read the full playbook →</p>
                </article>
              </a>
            </div>
          </AnimatedContent>
        </div>
      </section>
    )}

    {/* Blog Posts */}
    {blogPosts.length > 0 && (
      <section class="min-h-screen flex flex-col items-center justify-center px-3 md:px-8 lg:px-12 py-12 md:py-16">
        <div class="w-full max-w-5xl mx-auto text-base leading-relaxed index text-theme">
          <AnimatedContent delay={350}>
            <div class="w-full">
              <h2 class="text-2xl md:text-3xl font-light font-body !mb-0">Recent Writing</h2>
              <CardGrid columns={3} class="mt-12">
                {blogPosts.map((post, index) => (
                  <AnimatedContent delay={400 + (index * 50)}>
                    <BlogCard post={post} />
                  </AnimatedContent>
                ))}
              </CardGrid>
            </div>
          </AnimatedContent>
        </div>
      </section>
    )}
    
  </PageContent>
      <Footer />
      <ThemeToast />
    </BaseLayout>

<style>
  .hero-profile-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-profile-photo {
    width: 33%;
    height: auto;
    border-radius: 50%;
    object-fit: cover;
    aspect-ratio: 1 / 1;
    position: relative;
    z-index: 0;
    margin-bottom: -3.5rem;
    display: block;
  }

  .hero-profile-wrapper :global(.hero-shapes-wrapper) {
    position: relative;
    z-index: 1;
  }

  /* Craft dimensions grid — 4 > 2 > 1 columns */
  .craft-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    border: 1px solid var(--theme-border);
    border-radius: var(--theme-radius);
    overflow: hidden;
  }

  .craft-cell {
    padding: 1.25rem;
    background: var(--theme-bg);
    display: flex;
    flex-direction: column;
  }

  .craft-cell h3 {
    margin-bottom: 1.75rem !important;
    font-size: 1.125rem;
  }

  .craft-cell .ref-links {
    margin-top: auto;
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid var(--theme-border);
  }

  /* 1px borders between cells via background on parent */
  .craft-grid {
    background: var(--theme-border);
  }

  @media (max-width: 1024px) {
    .craft-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .craft-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Prevent hover effects on index content sections containing SVG images */
  .index-content-section {
    pointer-events: auto;
  }
  
  /* Remove hover effects from principle card divs containing SVG images */
  .index-content-section > div > div.my-8 {
    transition: none !important;
  }
  
  .index-content-section > div > div.my-8:hover {
    box-shadow: none !important;
    transform: none !important;
  }

  /* Section visuals styling - prevent text selection */
  .index-content-section svg,
  .index-content-section svg * {
    user-select: none !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
    pointer-events: none;
  }
  
  /* Re-enable pointer events for interactive elements if needed */
  .index-content-section svg path,
  .index-content-section svg circle,
  .index-content-section svg line,
  .index-content-section svg g {
    pointer-events: auto;
  }
  
  /* Specifically target text elements */
  .index-content-section svg text {
    user-select: none !important;
    -webkit-user-select: none !important;
    -moz-user-select: none !important;
    -ms-user-select: none !important;
    pointer-events: none !important;
  }
  
  .index-content-section svg {
    display: block;
    width: 100% !important;
    height: auto;
    max-width: 100% !important;
  }

  /* Force visual wrapper divs to fill container width */
  .index-content-section > div[class*="my-8"] {
    width: 100% !important;
    max-width: 100% !important;
    overflow: visible !important;
  }
  

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .index-content-section svg * {
      animation: none !important;
      transition: opacity 0.3s ease !important;
    }
  }

</style>

