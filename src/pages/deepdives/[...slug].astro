---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import PageContent from '../../components/ui/PageContent.astro';
import ThemeToast from '../../components/ui/ThemeToast.astro';
import CopyForAI from '../../components/blog/CopyForAI.tsx';
import JsonLd from '../../components/ui/JsonLd.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const deepdives = await getCollection('deepdives');
  return deepdives
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

interface Props {
  post: CollectionEntry<'deepdives'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const tocHeadings = headings.filter(
  (h) => (h.depth === 2 || h.depth === 3) && h.slug !== 'footnote-label'
);

const siteUrl = 'https://mmaxence.me';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Deep Dives', item: `${siteUrl}/deepdives/` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: `${siteUrl}/deepdives/${post.slug}/` },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description || post.data.title}
  featured_image={post.data.featured_image}
  url={new URL(`/deepdives/${post.slug}`, Astro.site).href}
  type="article"
>
  <JsonLd data={breadcrumbSchema} />
  <Header />
  <PageContent class="flex flex-col items-center pb-4 min-h-screen">
    <article class="max-w-3xl mx-auto px-3 md:px-6 py-12">
      {post.data.featured_image && (
        <div class="mb-8">
          <img
            src={post.data.featured_image}
            alt={post.data.title}
            class="w-full h-auto rounded-lg"
          />
        </div>
      )}

      <header class="mb-8">
        <h1 class="text-4xl md:text-5xl font-mono font-light mb-4">
          {post.data.title}
        </h1>
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <time class="text-sm" style="color: var(--theme-text-muted);">
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
          <CopyForAI client:load mdUrl={`/deepdives/${post.slug}.md`} />
        </div>
      </header>

      {tocHeadings.length > 2 && (
        <nav class="deepdive-toc mb-10 p-5 md:p-6" aria-label="Table of contents">
          <p class="text-xs uppercase tracking-widest mb-3" style="color: var(--theme-text-muted);">Contents</p>
          <ol class="list-none pl-0 space-y-1.5">
            {tocHeadings.map((h) => (
              <li class={h.depth === 3 ? 'toc-sub' : 'toc-main'}>
                <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <div class="prose prose-lg max-w-none leading-relaxed" style="color: var(--theme-text); opacity: 0.9;">
        <Content />
      </div>

      <style>
        .deepdive-toc {
          border: 1px solid var(--theme-border);
          border-radius: var(--theme-radius);
          background: var(--theme-bg);
        }
        .deepdive-toc .toc-main {
          font-size: 0.95rem;
          font-weight: 500;
        }
        .deepdive-toc .toc-sub {
          font-size: 0.9rem;
          padding-left: 1.25rem;
          color: var(--theme-text-muted);
        }
        .deepdive-toc .toc-link {
          color: var(--theme-text);
          text-decoration: none;
          border-bottom: none;
        }
        .deepdive-toc .toc-link:hover {
          color: var(--theme-accent, var(--theme-text));
          text-decoration: underline;
        }
        .deepdive-toc .toc-sub .toc-link {
          color: var(--theme-text-muted);
        }
        .deepdive-toc .toc-sub .toc-link:hover {
          color: var(--theme-text);
        }
        :global(html) {
          scroll-behavior: smooth;
        }
        :global(.prose h2),
        :global(.prose h3) {
          scroll-margin-top: 5rem;
        }
      </style>
    </article>
  </PageContent>
  <Footer />
  <ThemeToast />
</BaseLayout>
