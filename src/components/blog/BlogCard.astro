---
import type { CollectionEntry } from 'astro:content';
import DateDisplay from '../ui/DateDisplay.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;

const featuredImage = post.data.featured_image?.startsWith('/') 
  ? post.data.featured_image 
  : `/blog/${post.slug}/${post.data.featured_image}`;
---

<a href={`/blog/${post.slug}`} class={`blog-card-link block prefetch-link ${featured ? 'blog-card-featured' : ''}`} data-prefetch="true">
  <article class={`blog-card text-base leading-relaxed ${featured ? 'p-6 md:p-8' : 'p-6'} relative overflow-hidden`}>
    {post.data.featured_image && (
      <div class={`blog-card-image-wrap ${featured ? 'mb-5' : 'mb-4'}`}>
        <img
          src={featuredImage}
          alt={post.data.title}
          class="blog-card-image w-full h-auto transition-transform duration-300"
        />
      </div>
    )}
    <DateDisplay date={post.data.date} class="block mb-2 text-sm text-theme-muted" />
    <h2 class={`font-mono font-light mt-0 md:mt-2 mb-2 ${featured ? 'text-2xl md:text-3xl' : 'text-xl md:text-2xl'}`}>
      {post.data.title}
    </h2>
    <p class={`leading-relaxed ${featured ? 'text-base md:text-lg' : 'text-base'}`}>
      {post.data.description || 'Read the full article to learn more.'}
    </p>
  </article>
</a>

<style>
  .blog-card-link {
    text-decoration: none;
    color: inherit;
  }
  
  .blog-card-link:hover {
    text-decoration: none;
  }
  
  /* Card base styles */
  .blog-card {
    color: var(--theme-text);
    border: 1px solid var(--theme-border);
    border-radius: var(--radius-card);
    box-shadow: var(--theme-shadow);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .blog-card-link:hover .blog-card {
    border-color: var(--theme-accent);
    box-shadow: var(--theme-shadow-hover, 0 2px 8px rgba(0, 0, 0, 0.12));
    transform: translateY(-1px);
  }

  /* Image container - forces compositing layer so overflow: hidden works during transform */
  .blog-card-image-wrap {
    overflow: hidden;
    border-radius: var(--radius-card-image);
    isolation: isolate;
  }

  /* Image zoom effect on hover */
  .blog-card-image {
    transition: transform var(--transition-smooth);
  }

  .blog-card-link:hover .blog-card-image {
    transform: scale(1.05);
  }
</style>
