---
import type { CollectionEntry } from 'astro:content';
import TagList from '../ui/TagList.astro';
import BlogCard from './BlogCard.astro';
import CardGrid from '../ui/CardGrid.astro';

interface Props {
  currentPost: CollectionEntry<'blog'>;
  allPosts: CollectionEntry<'blog'>[];
}

const { currentPost, allPosts } = Astro.props;

// Sort by date descending (newest first)
const sorted = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentIndex = sorted.findIndex((p) => p.slug === currentPost.slug);
const prevPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextPost = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

// Related articles: posts sharing at least one tag, excluding current
const currentTags = currentPost.data.tags || [];
const related = currentTags.length > 0
  ? sorted
      .filter((p) => p.slug !== currentPost.slug)
      .map((p) => ({
        post: p,
        shared: (p.data.tags || []).filter((t: string) => currentTags.includes(t)).length,
      }))
      .filter((r) => r.shared > 0)
      .sort((a, b) => b.shared - a.shared)
      .slice(0, 2)
      .map((r) => r.post)
  : [];

---

{/* Tags */}
{currentTags.length > 0 && (
  <div class="mt-8">
    <TagList tags={currentTags} />
  </div>
)}

{/* Prev / Next navigation */}
<nav class="blog-post-nav mt-16 pt-8 border-t border-theme" aria-label="Blog post navigation">
  <div class="flex flex-col sm:flex-row justify-between gap-4">
    {prevPost ? (
      <a href={`/blog/${prevPost.slug}`} class="blog-nav-link group flex-1 relative" data-nav="prev">
        <span class="text-sm text-theme-muted">Previous</span>
        <span class="block mt-1 text-base text-theme group-hover:text-theme-accent transition-colors leading-snug">
          {prevPost.data.title}
        </span>
        {prevPost.data.description && (
          <span class="block mt-1 text-sm text-theme-muted leading-relaxed line-clamp-2">
            {prevPost.data.description}
          </span>
        )}
        <span class="hidden sm:inline blog-nav-key blog-nav-key-right">←</span>
      </a>
    ) : <div class="flex-1" />}
    {nextPost ? (
      <a href={`/blog/${nextPost.slug}`} class="blog-nav-link group flex-1 relative sm:text-right" data-nav="next">
        <span class="text-sm text-theme-muted">Next</span>
        <span class="block mt-1 text-base text-theme group-hover:text-theme-accent transition-colors leading-snug">
          {nextPost.data.title}
        </span>
        {nextPost.data.description && (
          <span class="block mt-1 text-sm text-theme-muted leading-relaxed line-clamp-2">
            {nextPost.data.description}
          </span>
        )}
        <span class="hidden sm:inline blog-nav-key blog-nav-key-left">→</span>
      </a>
    ) : <div class="flex-1" />}
  </div>
</nav>

{/* Related articles */}
{related.length > 0 && (
  <section class="mt-12 pt-8 border-t border-theme">
    <h2 class="text-lg font-mono font-light mb-6 text-theme-muted">Related</h2>
    <CardGrid columns={2}>
      {related.map((post) => (
        <BlogCard post={post} />
      ))}
    </CardGrid>
  </section>
)}

<style>
  .blog-nav-link {
    text-decoration: none;
    padding: 0.75rem;
    border: 1px solid var(--theme-border);
    border-radius: var(--theme-radius, 0.5rem);
    transition: border-color 0.2s ease;
  }

  .blog-nav-link:hover {
    border-color: var(--theme-accent);
  }

  .blog-nav-link::after {
    display: none !important;
  }

  .blog-nav-key {
    position: absolute;
    top: 0.75rem;
    font-size: 0.65rem;
    font-family: var(--theme-font-heading);
    line-height: 1;
    min-width: 1.4em;
    text-align: center;
    padding: 0.25rem 0.4rem 0.2rem;
    border-top: 1px solid var(--theme-border);
    border-left: 1px solid var(--theme-border);
    border-right: 2px solid var(--theme-border);
    border-bottom: 3px solid var(--theme-border);
    border-radius: 0.25rem;
    background-color: var(--theme-bg);
    color: var(--theme-text-muted);
    opacity: 0.6;
  }

  .blog-nav-key-right {
    right: 0.75rem;
  }

  .blog-nav-key-left {
    left: 0.75rem;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  function initBlogKeyboardNav() {
    const nav = document.querySelector('.blog-post-nav');
    if (!nav) return;

    const prevLink = nav.querySelector('[data-nav="prev"]') as HTMLAnchorElement | null;
    const nextLink = nav.querySelector('[data-nav="next"]') as HTMLAnchorElement | null;

    function onKeydown(e: KeyboardEvent) {
      // Don't navigate if user is typing in an input
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

      if (e.key === 'ArrowLeft' && prevLink) {
        prevLink.click();
      } else if (e.key === 'ArrowRight' && nextLink) {
        nextLink.click();
      }
    }

    document.addEventListener('keydown', onKeydown);

    // Cleanup on page transition
    document.addEventListener('astro:before-swap', () => {
      document.removeEventListener('keydown', onKeydown);
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBlogKeyboardNav);
  } else {
    initBlogKeyboardNav();
  }

  document.addEventListener('astro:page-load', () => {
    setTimeout(initBlogKeyboardNav, 50);
  });
</script>
